# --------------------------------------------------
# Google Cloud / Dataproc configuration
# --------------------------------------------------
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
GCP_CLUSTER=your-dataproc-cluster-name

# --------------------------------------------------
# Google Cloud Storage paths
# These are bucket-relative paths used by the Dataproc Spark job.
# Example final raw data locations:
# gs://your-bucket-name/NYC-taxi/
# gs://your-bucket-name/Weather.csv
# --------------------------------------------------
GCS_BUCKET=gs://your-bucket-name
RAW_TAXI_PATH=NYC-taxi
RAW_WEATHER_PATH=Weather.csv
FACT_OUTPUT_NAME=fact_taxi_demand
DIM_TIME_OUTPUT_NAME=dim_time
DIM_WEATHER_OUTPUT_NAME=dim_weather
DIM_LOCATION_OUTPUT_NAME=dim_location

# Optional: override the local Spark script path submitted to Dataproc.
SPARK_SCRIPT=Spark/spark-job.py

# --------------------------------------------------
# Snowflake configuration
# --------------------------------------------------
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Optional: override the default SQL file path.
SNOWFLAKE_SQL=Snowflake/snowflake_load.sql
